{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowJs": true,
    "isolatedModules": true,
    "lib": ["esnext", "dom"],
    "types": ["vite/client", "node", "element-plus/global"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "skipLibCheck": true
  },
  "include": ["components/*.vue", ".vitepress/**/*.vue", ".vitepress/**/*.ts", "types/**.d.ts"],
  "exclude": ["node_modules", "dist"]
}
